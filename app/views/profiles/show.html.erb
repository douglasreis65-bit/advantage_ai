<% content_for :body_class, "force-light-bg" %>

<div class="profile-container py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-6">

        <%# Header de Perfil %>
        <div class="mb-4">
          <h2 class="fw-bold text-main m-0">Configurações de Perfil</h2>
          <p class="text-muted small">Gerencie suas credenciais e preferências na AdVantageIA.</p>
        </div>

        <%# Card Principal de Edição %>
        <div class="profile-card shadow-sm p-4 mb-4">
          <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
            <%= f.error_notification %>

            <div class="form-inputs">
              <div class="mb-4">
                <label class="form-label-meta text-highlight">E-mail de Acesso</label>
                <%= f.input :email, required: true, autofocus: true, label: false, input_html: { class: "form-control-meta" } %>
              </div>

              <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
                <p class="text-muted small mb-3">Aguardando confirmação para: <strong><%= resource.unconfirmed_email %></strong></p>
              <% end %>

              <div class="row">
                <div class="col-md-6 mb-3">
                  <label class="form-label-meta">Nova Senha</label>
                  <%= f.input :password, required: false, label: false, placeholder: "Mínimo 6 caracteres", input_html: { class: "form-control-meta" } %>
                </div>
                <div class="col-md-6 mb-3">
                  <label class="form-label-meta">Confirmar Senha</label>
                  <%= f.input :password_confirmation, required: false, label: false, input_html: { class: "form-control-meta" } %>
                </div>
              </div>

              <hr class="my-4 opacity-50">

              <div class="mb-3">
                <label class="form-label-meta text-highlight">Confirmar com Senha Atual</label>
                <p class="text-muted x-small mb-2">Digite sua senha atual para validar as alterações.</p>
                <%= f.input :current_password, required: true, label: false, input_html: { class: "form-control-meta" } %>
              </div>
            </div>

            <div class="form-actions mt-4">
              <%= f.button :submit, "Atualizar Perfil", class: "btn-save-meta w-100" %>
            </div>
          <% end %>
        </div>

        <%# Card de Exclusão %>
        <div class="profile-card border-danger-subtle p-4">
          <h5 class="fw-bold text-danger mb-2">Encerrar Conta</h5>
          <p class="text-muted small mb-3">Esta ação é permanente. Todos os seus relatórios de performance e sugestões de criativos serão removidos.</p>
          <%= button_to "Excluir minha conta", registration_path(resource_name), data: { confirm: "Tem certeza?", turbo_confirm: "Tem certeza?" }, method: :delete, class: "btn-delete-link" %>
        </div>

        <div class="text-center mt-4">
          <%= link_to "← Voltar ao Início", root_path, class: "text-muted small text-decoration-none" %>
        </div>

      </div>
    </div>
  </div>
</div>
