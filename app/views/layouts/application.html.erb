<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Advantage Ai" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Advantage Ai">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "shared/navbar" %>

    <%# Só renderiza se houver mensagem, evitando o espaço em branco %>
    <% if notice %>
      <div class="alert alert-info alert-dismissible fade show m-0 border-0 rounded-0" role="alert" style="background: rgba(0, 245, 255, 0.1); color: #00F5FF; font-size: 0.8rem; text-align: center;">
        <%= notice %>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>

    <% if alert %>
      <div class="alert alert-warning alert-dismissible fade show m-0 border-0 rounded-0" role="alert" style="background: rgba(112, 0, 255, 0.1); color: #7000FF; font-size: 0.8rem; text-align: center;">
        <%= alert %>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
