<div class="analyses-new-container py-5" data-controller="campaign-form">
  <div class="container">
    <div class="row g-4">

      <%# COLUNA DA ESQUERDA: SIDEBAR DINÂMICA (STICKY) %>
      <div class="col-lg-4">
        <div class="guide-card p-4 sticky-top">
          <div class="d-flex align-items-center mb-3">
            <i class="fa-solid fa-robot text-primary me-2"></i>
            <h6 class="fw-bold text-main m-0" data-campaign-form-target="sidebarTitle">Configuração Inicial</h6>
          </div>

          <div data-campaign-form-target="sidebarContent">
            <p class="small text-muted mb-0">Selecione o objetivo e o local de conversão para calibrarmos o diagnóstico.</p>
          </div>

          <%# Lista Dinâmica de KPIs %>
          <div id="dynamic-instructions" class="mt-4 p-3 bg-light rounded border d-none" data-campaign-form-target="instructionBox">
            <p class="x-small fw-bold text-uppercase text-primary mb-2">Métricas para Selecionar:</p>
            <div class="kpi-tag-list d-flex flex-wrap gap-2 mb-0" data-campaign-form-target="kpiList">
              </div>
          </div>
        </div>
      </div>

      <%# COLUNA DA DIREITA: FORMULÁRIO %>
      <div class="col-lg-8">
        <div class="guide-card p-5">
          <%= simple_form_for(@analysis) do |f| %>
            <%= f.hidden_field :analysis_type, value: 'performance' %>

            <%# ETAPA 1: IDENTIFICAÇÃO %>
            <section id="step-1" class="mb-5">
              <h5 class="fw-bold text-main mb-4">1. Identificação da Campanha</h5>
              <div class="mb-4">
                <label class="form-label-meta">Conta de Anúncio Meta</label>
                <%= f.association :business_profile,
                    collection: current_user.business_profiles,
                    label: false,
                    prompt: "Selecione a conta de origem...",
                    input_html: { class: "form-select meta-input" } %>
              </div>

              <div class="row">
                <div class="col-md-6 mb-4">
                  <label class="form-label-meta">Objetivo</label>
                  <%= f.input :campaign_objective,
                      collection: [['Reconhecimento', 'reconhecimento'], ['Tráfego', 'trafego'], ['Engajamento', 'engajamento'], ['Leads', 'leads'], ['Vendas', 'vendas']],
                      label: false,
                      prompt: "Selecione o objetivo...",
                      input_html: { data: { action: "change->campaign-form#updateTree" }, class: "form-select meta-input" } %>
                </div>
                <div class="col-md-6 mb-4">
                  <label class="form-label-meta">Local da Conversão</label>
                  <%= f.input :conversion_location,
                      collection: [],
                      label: false,
                      prompt: "Aguardando objetivo...",
                      input_html: { data: { campaign_form_target: "locationSelect" }, class: "form-select meta-input" } %>
                </div>
              </div>
              <button type="button" class="btn-launch w-100" data-action="click->campaign-form#goToStep2">
                Prosseguir para Dados de Pixel <i class="fa-solid fa-chevron-right ms-2"></i>
              </button>
            </section>

            <%# ETAPA 2: PIXEL %>
            <section id="step-2" class="mb-5 d-none animate__animated animate__fadeIn" data-campaign-form-target="step2">
              <hr class="my-5">
              <h5 class="fw-bold text-main mb-4">2. Gerenciador de Eventos (Pixel)</h5>
              <div class="upload-zone p-5 text-center mb-4 border-dashed">
                <i class="fa-solid fa-database text-primary mb-3 opacity-50 display-6"></i>
                <p class="small text-muted mb-3">Relatório de Eventos para análise de funil.</p>
                <input type="file" class="form-control form-control-sm">
              </div>
              <div class="d-flex gap-3">
                <button type="button" class="btn btn-light flex-grow-1" data-action="click->campaign-form#goToStep3">Ignorar</button>
                <button type="button" class="btn-launch flex-grow-1" data-action="click->campaign-form#goToStep3">Salvar e Prosseguir</button>
              </div>
            </section>

            <%# ETAPA 3: CRIATIVOS %>
            <section id="step-3" class="mb-5 d-none animate__animated animate__fadeIn" data-campaign-form-target="step3">
              <hr class="my-5">
              <h5 class="fw-bold text-main mb-4">3. Upload de Criativos</h5>
              <div class="upload-zone p-5 text-center mb-4 border-dashed">
                <i class="fa-solid fa-wand-magic-sparkles text-primary mb-3 opacity-50 display-6"></i>
                <p class="small text-muted mb-3">Envie até 5 arquivos para análise estética e de retenção.</p>
                <input type="file" class="form-control form-control-sm" multiple>
              </div>
              <div class="d-flex gap-3">
                <button type="button" class="btn btn-light flex-grow-1" data-action="click->campaign-form#goToStep4">Ignorar</button>
                <button type="button" class="btn-launch flex-grow-1" data-action="click->campaign-form#goToStep4">Salvar e Prosseguir</button>
              </div>
            </section>

            <%# ETAPA 4: RELATÓRIO PREMIUM %>
            <section id="step-4" class="mb-5 d-none animate__animated animate__fadeIn" data-campaign-form-target="step4">
              <hr class="my-5">
              <h5 class="fw-bold text-main mb-4">4. Relatório de Campanha (Ads Reporting)</h5>

              <div class="alert alert-info border-0 shadow-sm rounded-4 p-4 mb-4">
                <div class="d-flex align-items-center">
                  <i class="fa-solid fa-circle-info fs-4 me-3 text-info"></i>
                  <p class="small mb-0">
                    Acesse o ícone de <strong>Relatórios</strong> na barra lateral esquerda da Meta e use o painel <strong>'Personalizar tabela dinâmica'</strong> à direita para selecionar as métricas.
                  </p>
                </div>
              </div>

              <div class="upload-zone p-5 text-center border-primary bg-light">
                <i class="fa-solid fa-file-csv text-primary mb-3 display-6"></i>
                <p class="small fw-bold mb-3">Suba o relatório CSV extraído da Meta</p>
                <%= f.input :campaign_csv, as: :file, label: false, input_html: { class: "form-control" } %>
              </div>
              <%= f.button :submit, "Lançar Diagnóstico Premium", class: "btn-launch w-100 mt-4 py-3" %>
            </section>

          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
