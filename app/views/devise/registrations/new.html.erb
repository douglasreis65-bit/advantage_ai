<div class="auth-container">
  <div class="auth-card-wrapper">

    <div class="auth-header">
      <h2 class="auth-title">Criar sua conta</h2>
      <p class="auth-subtitle text-slate-500">Comece a otimizar suas campanhas com IA hoje mesmo.</p>
    </div>

    <div class="auth-card">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="form-group">
          <%= f.label :email, "E-mail profissional" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "seu@email.com" %>
        </div>

        <div class="form-group">
          <%= f.label :password, "Senha" %>
          <% if @minimum_password_length %>
            <em class="text-xs text-slate-400 font-normal">(mínimo de <%= @minimum_password_length %> caracteres)</em>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••" %>
        </div>

        <div class="form-group">
          <%= f.label :password_confirmation, "Confirme sua senha" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••" %>
        </div>

        <div class="form-actions mt-4">
          <%= f.submit "Criar minha conta", class: "btn-primary-full" %>
        </div>
      <% end %>

      <div class="auth-divider">
        <span>Já utiliza o AdvantageIA?</span>
      </div>

      <div class="auth-secondary-action">
        <%= link_to "Acessar minha conta", new_user_session_path, class: "btn-secondary-full" %>
      </div>
    </div>

    <footer class="auth-footer">
      ADVANTAGE I.A. © 2026
    </footer>
  </div>
</div>
